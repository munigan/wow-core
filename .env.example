DATABASE_URL=postgresql://wow:wow@localhost:5432/wow_core
BETTER_AUTH_SECRET=generate-a-random-secret-here
# Production: full URL with scheme, e.g. https://wow-raid-tools.munigan.app (host-only is normalized to https)
BETTER_AUTH_URL=http://localhost:3000
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Trigger.dev (background tasks — https://trigger.dev/docs/manual-setup)
# Dashboard → API Keys: DEV secret for local / app triggers
TRIGGER_SECRET_KEY=
# Dashboard → Project: project ref (e.g. proj_…), used by trigger.config.ts
TRIGGER_PROJECT_REF=
# For deployed tasks that use Drizzle (e.g. fetch-warmane-item-data), set the same
# DATABASE_URL in the Trigger.dev project → Environment variables (dev/staging/prod).
